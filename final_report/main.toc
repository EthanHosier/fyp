\contentsline {chapter}{\numberline {5}Threats to validity}{57}{chapter.5}%
\contentsline {section}{\numberline {5.1}Construct validity}{57}{section.5.1}%
\contentsline {paragraph}{There is no external ground truth for ``true refactoring quality''.}{57}{section*.80}%
\contentsline {paragraph}{The score is not a maintainability index.}{57}{section*.81}%
\contentsline {paragraph}{The four-kind taxonomy is a methodology choice, not a discovered structure.}{57}{section*.82}%
\contentsline {paragraph}{\texttt {SuboptimalOrdering} is author-claimed, not measured.}{58}{section*.83}%
\contentsline {paragraph}{The AST-equivalence audit uses an informal definition.}{58}{section*.84}%
\contentsline {section}{\numberline {5.2}Internal validity}{58}{section.5.2}%
\contentsline {paragraph}{The single-knob sensitivity sweep is combined with a multi-knob design rather than replaced.}{58}{section*.85}%
\contentsline {paragraph}{Kind-presence agreement does not imply rank-order agreement.}{58}{section*.86}%
\contentsline {paragraph}{Cleanliness sub-weights are uniform $1.0$ by Laplace's principle of insufficient reason.}{59}{section*.87}%
\contentsline {paragraph}{The lag term couples the cleanliness sub-score to the process score.}{59}{section*.88}%
\contentsline {paragraph}{Two batching primitives are heuristic and not sensitivity-tested.}{59}{section*.89}%
\contentsline {paragraph}{The production weight vector is hand-picked within a literature-grounded ordering.}{59}{section*.90}%
\contentsline {paragraph}{Which terms carry the ranking varies by session type.}{59}{section*.91}%
\contentsline {paragraph}{The reorder dependency analysis is deliberately coarse, and anchors are content-addressed.}{60}{section*.92}%
\contentsline {paragraph}{Cleanliness sub-signals are clamped to the user's range on alternative trajectories.}{60}{section*.93}%
\contentsline {section}{\numberline {5.3}External validity}{60}{section.5.3}%
\contentsline {paragraph}{The injection sessions are scoped exercises, not naturalistic sessions.}{60}{section*.94}%
\contentsline {paragraph}{The user study has five participants split into a randomised three-vs-two arm.}{61}{section*.95}%
\contentsline {paragraph}{The agent extension is a feasibility experiment, not an agent evaluation.}{61}{section*.96}%
\contentsline {paragraph}{All sessions are single-author IntelliJ sessions on a Gradle Java project.}{61}{section*.97}%
\contentsline {paragraph}{The detectors are designed for human edit patterns.}{61}{section*.98}%
\contentsline {paragraph}{Refactoring kinds the synthesiser cannot handle are excluded by construction.}{62}{section*.99}%
