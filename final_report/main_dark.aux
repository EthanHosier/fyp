\@writefile{toc}{\contentsline {chapter}{\numberline {5}Threats to validity}{56}{chapter.5}\protected@file@percent }
\@writefile{lof}{\addvspace {10\p@ }}
\@writefile{lot}{\addvspace {10\p@ }}
\newlabel{ch:threats}{{5}{56}{Threats to validity}{chapter.5}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5.1}Construct validity}{56}{section.5.1}\protected@file@percent }
\newlabel{sec:threats-construct}{{5.1}{56}{Construct validity}{section.5.1}{}}
\@writefile{toc}{\contentsline {paragraph}{There is no external ground truth for ``true refactoring quality''.}{56}{section*.80}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The score is not a maintainability index.}{56}{section*.81}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The four-kind taxonomy is a methodology choice, not a discovered structure.}{56}{section*.82}\protected@file@percent }
\citation{murphyhill2009howrefactor}
\@writefile{toc}{\contentsline {paragraph}{\texttt  {SuboptimalOrdering} is author-claimed, not measured.}{57}{section*.83}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The AST-equivalence audit uses an informal definition.}{57}{section*.84}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {5.2}Internal validity}{57}{section.5.2}\protected@file@percent }
\newlabel{sec:threats-internal}{{5.2}{57}{Internal validity}{section.5.2}{}}
\@writefile{toc}{\contentsline {paragraph}{The single-knob sensitivity sweep is combined with a multi-knob design rather than replaced.}{57}{section*.85}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Kind-presence agreement does not imply rank-order agreement.}{57}{section*.86}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Cleanliness sub-weights are uniform $1.0$ by Laplace's principle of insufficient reason.}{57}{section*.87}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Two batching primitives are heuristic and not sensitivity-tested.}{58}{section*.88}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The production weight vector is hand-picked within a literature-grounded ordering.}{58}{section*.89}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Which terms carry the ranking varies by session type.}{58}{section*.90}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The reorder dependency analysis is deliberately coarse, and anchors are content-addressed.}{58}{section*.91}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Cleanliness sub-signals are clamped to the user's range on alternative trajectories.}{59}{section*.92}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {5.3}External validity}{59}{section.5.3}\protected@file@percent }
\newlabel{sec:threats-external}{{5.3}{59}{External validity}{section.5.3}{}}
\@writefile{toc}{\contentsline {paragraph}{The injection sessions are scoped exercises, not naturalistic sessions.}{59}{section*.93}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The user study has two participants and twelve sessions.}{59}{section*.94}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The agent comparison is a single agent over six sessions.}{59}{section*.95}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{All sessions are single-author IntelliJ sessions on a Gradle Java project.}{59}{section*.96}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Refactoring kinds the synthesiser cannot handle are excluded by construction.}{59}{section*.97}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {5.4}Statistical conclusion validity}{60}{section.5.4}\protected@file@percent }
\newlabel{sec:threats-statistical}{{5.4}{60}{Statistical conclusion validity}{section.5.4}{}}
