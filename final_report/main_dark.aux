\@writefile{lot}{\contentsline {table}{\numberline {4.1}{\ignorespaces Single-knob sensitivity across the rankable subsets of the three session types ($\geq 2$ detected divergence points per session). The clamp-frozen rate is the share of $(\text  {DP} \times \text  {perturbation})$ cases where the user trajectory-final and the DP's alt trajectory-final both sit at the same $[0, 100]$ clamp value in baseline and in perturbed; for those cases the magnitude $J(\text  {alt}_T) - J(\text  {user}_T)$ is identical by construction, contributing trivially to $\tau = 1$. Only $1.8\%$ of user-study cases are clamp-frozen, so the $96.5\%$ top-$1$ figure is overwhelmingly genuine perturbation response rather than clamp-driven invariance.}}{38}{table.caption.38}\protected@file@percent }
\newlabel{tab:results-sensitivity-headline}{{4.1}{38}{Single-knob sensitivity across the rankable subsets of the three session types ($\geq 2$ detected divergence points per session). The clamp-frozen rate is the share of $(\text {DP} \times \text {perturbation})$ cases where the user trajectory-final and the DP's alt trajectory-final both sit at the same $[0, 100]$ clamp value in baseline and in perturbed; for those cases the magnitude $J(\text {alt}_T) - J(\text {user}_T)$ is identical by construction, contributing trivially to $\tau = 1$. Only $1.8\%$ of user-study cases are clamp-frozen, so the $96.5\%$ top-$1$ figure is overwhelmingly genuine perturbation response rather than clamp-driven invariance}{table.caption.38}{}}
\@writefile{toc}{\contentsline {paragraph}{Sources of ranking instability.}{38}{section*.39}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.2}{\ignorespaces Per-knob top-$1$ disruption counts on the user-study rankable subset (25 sessions $\times $ 9 perturbation factors $=$ 225 cases per weight). Most top-$1$ shifts come from the process-side weights, especially $W_{\textsc  {g}}$; the lag weight changes the top-ranked item only once, and the cleanliness sub-weights have little effect.}}{39}{table.caption.40}\protected@file@percent }
\newlabel{tab:results-sensitivity-knobs}{{4.2}{39}{Per-knob top-$1$ disruption counts on the user-study rankable subset (25 sessions $\times $ 9 perturbation factors $=$ 225 cases per weight). Most top-$1$ shifts come from the process-side weights, especially $W_{\textsc {g}}$; the lag weight changes the top-ranked item only once, and the cleanliness sub-weights have little effect}{table.caption.40}{}}
\@writefile{toc}{\contentsline {paragraph}{Multi-knob Monte Carlo.}{39}{section*.41}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.3}{\ignorespaces Multi-knob Monte Carlo robustness across the rankable subsets ($200$ samples per session, log-normal $\sigma = \ln 2$). The user-study set carries the headline because it has the largest rankable subset and the longest per-session rankings. Multi-knob top-$1$ stability is $\sim 12$ percentage lower than the single-knob result on the same set. Top-$3$ and top-$5$ track top-$1$ on the agent set ($78.3\%$ and $75.0\%$) but drop on the user-study set ($61.7\%$ and $59.5\%$), where longer per-session rankings leave more lower-ranked divergence points available to reorder. The injection top-$3$/top-$5$ figures fall sharply because injection rankings have at most $5$ items, so one lower-ranked swap can affect both metrics at once.}}{39}{table.caption.42}\protected@file@percent }
\newlabel{tab:results-sensitivity-mc}{{4.3}{39}{Multi-knob Monte Carlo robustness across the rankable subsets ($200$ samples per session, log-normal $\sigma = \ln 2$). The user-study set carries the headline because it has the largest rankable subset and the longest per-session rankings. Multi-knob top-$1$ stability is $\sim 12$ percentage lower than the single-knob result on the same set. Top-$3$ and top-$5$ track top-$1$ on the agent set ($78.3\%$ and $75.0\%$) but drop on the user-study set ($61.7\%$ and $59.5\%$), where longer per-session rankings leave more lower-ranked divergence points available to reorder. The injection top-$3$/top-$5$ figures fall sharply because injection rankings have at most $5$ items, so one lower-ranked swap can affect both metrics at once}{table.caption.42}{}}
