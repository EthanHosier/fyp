\@writefile{lot}{\contentsline {table}{\numberline {4.5}{\ignorespaces Per-term single-knob recovery (each term active alone, others zeroed). The \texttt  {length} and \texttt  {broken} terms are the strongest contributors by both mean recovery and sum/sum; the new \texttt  {lag} term is fourth on both. \texttt  {gain} alone recovers $0.000$ because the cleanliness delta is near zero on most fixtures, so it has no effect when isolated.}}{43}{table.caption.55}\protected@file@percent }
\newlabel{tab:results-ablation-solo}{{4.5}{43}{Per-term single-knob recovery (each term active alone, others zeroed). The \texttt {length} and \texttt {broken} terms are the strongest contributors by both mean recovery and sum/sum; the new \texttt {lag} term is fourth on both. \texttt {gain} alone recovers $0.000$ because the cleanliness delta is near zero on most fixtures, so it has no effect when isolated}{table.caption.55}{}}
\@writefile{toc}{\contentsline {paragraph}{Per-term leave-one-out recovery.}{43}{section*.56}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.6}{\ignorespaces Per-term leave-one-out recovery (six terms active, one removed). Removing \texttt  {length} causes the largest sum/sum drop; removing \texttt  {gain} inflates sum/sum above $1.000$, indicating that \texttt  {gain} regularises against the penalty terms rather than acting as a positive contributor in isolation. Removing the new \texttt  {lag} term costs $0.158$ on sum/sum while leaving the ranking essentially intact ($\tau = 0.996$).}}{43}{table.caption.57}\protected@file@percent }
\newlabel{tab:results-ablation-loo}{{4.6}{43}{Per-term leave-one-out recovery (six terms active, one removed). Removing \texttt {length} causes the largest sum/sum drop; removing \texttt {gain} inflates sum/sum above $1.000$, indicating that \texttt {gain} regularises against the penalty terms rather than acting as a positive contributor in isolation. Removing the new \texttt {lag} term costs $0.158$ on sum/sum while leaving the ranking essentially intact ($\tau = 0.996$)}{table.caption.57}{}}
