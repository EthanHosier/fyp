# Provider plugins; regenerated by `terraform init`.
.terraform/

# Local state — never commit. Use a remote backend (S3 + DynamoDB lock,
# Terraform Cloud, etc.) for shared state in real deploys.
*.tfstate
*.tfstate.*
*.tfstate.backup

# Variable overrides; may contain secrets.
*.tfvars
!example.tfvars

# Crash logs.
crash.log
crash.*.log
